SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=write_products

# PostgreSQL connection string used by the running app (recommended: Neon pooled URL)
# For Neon use sslmode=require. When using the pooled endpoint, include pgbouncer=true.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# Direct PostgreSQL connection for Prisma migrations (recommended: Neon non-pooled URL)
# Prisma uses this for migrate/deploy operations when defined.
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: custom shop domain if you use one
SHOP_CUSTOM_DOMAIN=

# Required for Smart Crop integration (deployed FastAPI service URL)
# Example: https://smart-crop-api.onrender.com
SMARTCROP_API_URL=

NODE_ENV=production
