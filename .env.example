SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=write_products

# Managed PostgreSQL connection string (Render or equivalent)
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# Optional: custom shop domain if you use one
SHOP_CUSTOM_DOMAIN=

# Required for Smart Crop integration (deployed FastAPI service URL)
# Example: https://smart-crop-api.onrender.com
SMARTCROP_API_URL=

NODE_ENV=production
